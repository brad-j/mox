# mox reads connection settings from a `.env` file (same schema as the sibling
# `pve` bash tool). Copy this to `.env` and fill in, or point mox at an existing
# file with:  PVE_CONFIG_FILE=/path/to/.env mox
#
# Discovery order: $PVE_CONFIG_FILE → nearest `.env` walking up from the cwd →
# ~/.config/pve/.env

PVE_HOST=192.0.2.10                       # Proxmox node IP or hostname (required)
PVE_USER=root                             # SSH user (default: root)
PVE_SSH_PORT=22                           # SSH port (default: 22)
PVE_IDENTITY_FILE="$HOME/.ssh/proxmox/id_ed25519"  # SSH key (optional)
